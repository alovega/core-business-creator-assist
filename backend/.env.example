# Application environment: development | testing | staging | production
FLASK_ENV=development

# Flask
SECRET_KEY=change-me-in-production
JWT_SECRET=change-me-in-production-jwt

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/business_creator
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/business_creator_test

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
TEST_REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0

# Meta (webhook signature verification)
META_APP_SECRET=

# AI provider
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# Object storage (local | s3)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=uploads
STORAGE_BUCKET=
STORAGE_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Frontend (CORS, redirects, links in notifications)
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=INFO
LOG_JSON=true

# Server (run.py)
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
